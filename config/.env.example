# FinanceSail - 环境变量配置模板
# 复制此文件为 .env 并填入实际值

# ==================== DeepSeek AI ====================
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ==================== LiteLLM 多模型（可选） ====================
# 备用模型，当 DeepSeek 不可用时自动切换
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
LITELLM_FALLBACK_MODEL=openai/gpt-4o-mini
LITELLM_ROUTING_STRATEGY=simple-shuffle

# ==================== Tushare ====================
TUSHARE_TOKEN=your_tushare_token_here

# ==================== QQ邮箱（旧版兼容） ====================
QQ_EMAIL=your_email@qq.com
QQ_EMAIL_AUTH_CODE=your_16_char_auth_code_here
RECEIVER_EMAIL=receiver@example.com

# ==================== SMTP配置 ====================
SMTP_SERVER=smtp.qq.com
SMTP_PORT=465

# ==================== 多渠道通知 ====================
# 企业微信 Webhook
WECHAT_WEBHOOK_URL=

# 飞书 Webhook
FEISHU_WEBHOOK_URL=

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 邮件（新版，优先于 QQ_EMAIL）
EMAIL_SENDER=
EMAIL_PASSWORD=
EMAIL_RECEIVERS=

# PushPlus
PUSHPLUS_TOKEN=
PUSHPLUS_TOPIC=

# ==================== 交易策略 ====================
STRATEGIES_DIR=strategies
# 激活的策略名称（逗号分隔），可选值：bull_trend, ma_golden_cross, chan_theory, wave_theory
ACTIVE_STRATEGIES=bull_trend

# ==================== 交易日历 ====================
TRADING_CALENDAR_CN=XSHG
TRADING_CALENDAR_US=XNYS
TRADING_CALENDAR_HK=XHKG

# ==================== 报告渲染 ====================
# 报告语言：zh（中文）/ en（英文）
REPORT_LANGUAGE=zh
# 报告类型：simple / full / brief
REPORT_TYPE=full
# 仅输出摘要（true/false）
REPORT_SUMMARY_ONLY=false

# ==================== 日志配置 ====================
LOG_LEVEL=INFO
LOG_ROTATION=10 MB
LOG_RETENTION=30 days

# ==================== 定时任务时间 ====================
US_STOCK_TIME=09:00
A_SHARE_TIME=17:00
HOT_STOCK_TIME=17:30
IPO_TIME=20:00
